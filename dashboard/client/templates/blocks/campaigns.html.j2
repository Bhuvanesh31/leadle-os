{# dashboard/client/templates/blocks/campaigns.html.j2 — 4-box ranked layout.
   Boxes: top email campaigns, top email steps, top LinkedIn campaigns, top LinkedIn variants.
   WoW arrows/tooltips on campaigns + variants; email steps render plain (no stable identity). #}
{% from "blocks/_wow.html.j2" import arrow, tip with context %}

{# --- Box 1: Top email campaigns (reply → click → open; 0-open excluded) --- #}
<div class="sec">
  <div class="sec-h">
    <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
    <span class="t">Which campaign performed</span>
    <span class="s">&middot; email reply&rarr;click&rarr;open &middot; top 5 by performance</span>
  </div>
{% if metrics.boxes.email_campaigns %}
  <table>
    <thead><tr><th>Campaign</th><th class="num">Sent</th><th class="num">Reply</th><th class="num">Click</th><th class="num">Open</th><th class="num">Bounce</th><th class="num">Grade</th></tr></thead>
    <tbody>
      {% for c in metrics.boxes.email_campaigns %}
      <tr>
        <td class="camp">{{ c.name }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.sent') }}>{{ c.sent }}{{ arrow('campaign.' ~ c.name ~ '.sent') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.reply_rate') }}>{{ '%.1f%%' % (c.reply_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.reply_rate') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.click_rate') }}>{{ '%.1f%%' % (c.click_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.click_rate') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.open_rate') }}>{{ '%.0f%%' % (c.open_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.open_rate') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.bounce_rate') }}>{% if c.bounce_rate is not none %}{{ '%.1f%%' % (c.bounce_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.bounce_rate') }}{% else %}&mdash;{% endif %}</td>
        <td class="num"><span class="grade g-{{ c.grade }}">{{ c.grade }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if metrics.boxes.excluded.email %}
  <div class="note">Excluded (0 opens): {{ metrics.boxes.excluded.email | join(', ') }}.</div>
  {% endif %}
{% else %}
  <div class="note">No performing email campaigns this period.</div>
{% endif %}
</div>

{# --- Box 2: Top email steps (which content performed; plain — no WoW arrows) --- #}
<div class="sec" style="margin-top:16px">
  <div class="sec-h">
    <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
    <span class="t">Which content performed</span>
    <span class="s">&middot; email steps by open rate &middot; top 5</span>
  </div>
{% if metrics.boxes.email_steps %}
  <table>
    <thead><tr><th>Step</th><th class="num">Open</th></tr></thead>
    <tbody>
      {% for s in metrics.boxes.email_steps %}
      <tr>
        <td class="k">{{ s.label }}<div class="content-line">{{ s.subject }}{% if s.body_preview %} &middot; {{ s.body_preview }}{% endif %}</div></td>
        <td class="num">{{ '%.0f%%' % (s.open_rate*100) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <div class="note">Open rate is shown (reply rate is typically 0% on individual steps). Week-to-week comparison not shown — step identity changes each period.</div>
{% else %}
  <div class="note">No per-step data available this period.</div>
{% endif %}
</div>

{# --- Box 3: Top LinkedIn campaigns (reply → accept; 0-connection excluded) --- #}
<div class="sec" style="margin-top:16px">
  <div class="sec-h">
    <svg class="ic" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.3 18.3H5.7V9.7h2.6zM7 8.5A1.5 1.5 0 1 1 7 5.5a1.5 1.5 0 0 1 0 3zM18.3 18.3h-2.6v-4.2c0-1-.4-1.7-1.3-1.7-.7 0-1.1.5-1.3 1-.1.2-.1.5-.1.7v4.2h-2.6V9.7h2.6v1.1c.3-.5 1-1.3 2.4-1.3 1.7 0 2.9 1.1 2.9 3.5z"/></svg>
    <span class="t">Which LinkedIn message worked</span>
    <span class="s">&middot; campaigns by reply&rarr;accept &middot; top 5</span>
  </div>
{% if metrics.boxes.linkedin_campaigns %}
  <table>
    <thead><tr><th>Campaign</th><th class="num">Invites</th><th class="num">Connects</th><th class="num">Accept %</th><th class="num">Reply %</th></tr></thead>
    <tbody>
      {% for c in metrics.boxes.linkedin_campaigns %}
      <tr>
        <td class="camp">{{ c.name }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.invites') }}>{{ c.invites }}{{ arrow('campaign.' ~ c.name ~ '.invites') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.connections') }}>{{ c.connections }}{{ arrow('campaign.' ~ c.name ~ '.connections') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.accept_rate') }}>{{ '%.1f%%' % (c.accept_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.accept_rate') }}</td>
        <td class="num" {{ tip('campaign.' ~ c.name ~ '.reply_rate') }}>{{ '%.1f%%' % (c.reply_rate*100) }}{{ arrow('campaign.' ~ c.name ~ '.reply_rate') }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if metrics.boxes.excluded.linkedin %}
  <div class="note">Excluded (0 connections): {{ metrics.boxes.excluded.linkedin | join(', ') }}.</div>
  {% endif %}
{% else %}
  <div class="note">No performing LinkedIn campaigns this period.</div>
{% endif %}
</div>

{# --- Box 4: Top LinkedIn variants (by reply → accept) --- #}
<div class="sec" style="margin-top:16px">
  <div class="sec-h">
    <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
    <span class="t">Which LinkedIn variant worked</span>
    <span class="s">&middot; message variants by reply&rarr;accept &middot; top 5</span>
  </div>
{% if metrics.boxes.linkedin_variants %}
  <table>
    <thead><tr><th>Variant</th><th class="num">Accept %</th><th class="num">Replies</th><th class="num">Reply %</th></tr></thead>
    <tbody>
      {% for v in metrics.boxes.linkedin_variants %}
      <tr>
        <td class="k">{{ v.name }}{% if v.winner %} <span class="best">winner</span>{% endif %}<div class="content-line">{{ v.hook }}</div></td>
        <td class="num" {{ tip('variant.' ~ v.name ~ '.accept_rate') }}>{{ '%.1f%%' % (v.accept_rate*100) }}{{ arrow('variant.' ~ v.name ~ '.accept_rate') }}</td>
        <td class="num" {{ tip('variant.' ~ v.name ~ '.replies') }}>{{ v.replies }}{{ arrow('variant.' ~ v.name ~ '.replies') }}</td>
        <td class="num" {{ tip('variant.' ~ v.name ~ '.reply_rate') }}>{{ '%.1f%%' % (v.reply_rate*100) }}{{ arrow('variant.' ~ v.name ~ '.reply_rate') }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% else %}
  <div class="note">No LinkedIn variant data this period.</div>
{% endif %}
</div>
