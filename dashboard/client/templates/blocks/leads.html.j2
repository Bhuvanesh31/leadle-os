{# dashboard/client/templates/blocks/leads.html.j2 — warm & named leads (approved design) #}
{% set L = metrics.leads %}
<div class="sec">
  <div class="sec-h"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg><span class="t">Warm &amp; named leads</span><span class="s">&middot; positives and booked meetings</span></div>
{% if L.hot %}
  <table>
    <thead><tr><th>Name</th><th>Title</th><th>Company</th><th>Channel</th><th>Status</th></tr></thead>
    <tbody>
      {% for x in L.hot %}
      <tr>
        <td class="k"><span class="hdot d-ok"></span>{{ x.name }}</td>
        <td>{{ x.title }}</td>
        <td>{{ x.company }}</td>
        <td>{{ x.channel }}</td>
        <td>{{ x.tier }} &middot; {{ x.status }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% else %}
  <div class="note">No positive leads yet &mdash; campaign is live.</div>
{% endif %}
  <div class="note">{{ L.reached }} reached &middot; {{ L.warm_count }} accepted (reach) &middot; {{ L.positive_leads }} positive &middot; {{ L.meetings }} meetings.</div>
</div>
