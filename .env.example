# Leadle OS — environment variables
# Copy this file to .env and fill in the values. NEVER commit .env.

# ─── Supabase ─────────────────────────────────────────────────────────
# From https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── HubSpot ──────────────────────────────────────────────────────────
# HubSpot MCP is configured at the claude.ai workspace level, not via env.
# These vars are kept only for legacy or fallback scripts (rare).
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=

# ─── Outbound tools ───────────────────────────────────────────────────
LEMLIST_API_KEY=
AIMFOX_API_KEY=
INSTANTLY_API_KEY=

# ─── Fathom ───────────────────────────────────────────────────────────
FATHOM_API_KEY=

# ─── Slack ────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...) with at least chat:write, im:write, files:write
SLACK_BOT_TOKEN=

# Channel/DM IDs — fetch via Slack workspace > channel info
SLACK_BRIEF_RECIPIENT=          # Sai's user ID (DM target) e.g. U01234567
SLACK_OPS_CHANNEL=              # #leadle-os-ops channel ID
SLACK_INSIGHTS_CHANNEL=         # sales+marketing cross-pollination channel ID

# ─── Anthropic ────────────────────────────────────────────────────────
# For agents invoked outside a Claude Code session (e.g., in scheduled scripts)
ANTHROPIC_API_KEY=

# ─── Runtime ──────────────────────────────────────────────────────────
LEADLE_OS_ENV=dev               # dev | prod — gates dry-run behaviors
LEADLE_OS_TZ=Asia/Kolkata       # IST for all scheduled runs
LEADLE_OS_LOG_LEVEL=INFO
